<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.NavigationDrawer" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/content_bg</item>
        <item name="colorPrimaryVariant">@color/content_bg</item>
        <item name="colorOnPrimary">@color/content_text</item>
        <item name="colorSecondary">@color/color_accent</item>
        <item name="android:statusBarColor">@color/content_bg</item>
        <item name="android:navigationBarColor">@color/content_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="ThemeOverlay.NavigationDrawer.Toolbar" parent="ThemeOverlay.MaterialComponents.Light">
        <item name="colorOnPrimary">@color/content_text</item>
    </style>

    <style name="ShapeAppearance.NavigationDrawer.Item" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="TextAppearance.NavigationDrawer.Item" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/nav_item_text</item>
        <item name="android:textStyle">normal</item>
    </style>

</resources>
